# Required: WAHA API base URL (no trailing slash)
WAHA_API_URL=http://localhost:3000/api

# Required: WAHA API key
WAHA_API_KEY=your-api-key-here

# Optional: Session name (default: "default")
WAHA_SESSION=default

# Optional: Minimum delay between outbound messages in ms (default: 1000)
WAHA_SEND_DELAY_MS=1000

# ── Transcription (optional) ──────────────────────────────────────
# Required for whatsapp_transcribe_audio tool. Uses OpenAI Whisper API by default.
# Can point to any OpenAI-compatible transcription endpoint (faster-whisper-server, Groq, etc.)

# API key for the transcription service (e.g., OpenAI API key)
# WAHA_TRANSCRIPTION_API_KEY=sk-...

# Transcription endpoint URL (default: OpenAI)
# WAHA_TRANSCRIPTION_URL=https://api.openai.com/v1/audio/transcriptions

# Model name (default: "whisper-1" for OpenAI, use "large-v3" for faster-whisper)
# WAHA_TRANSCRIPTION_MODEL=whisper-1

# Language hint for better accuracy (ISO 639-1, e.g., "pt" for Portuguese)
# WAHA_TRANSCRIPTION_LANGUAGE=pt
