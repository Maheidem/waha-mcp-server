# Required: WAHA API base URL (no trailing slash)
WAHA_API_URL=http://localhost:3000/api

# Required: WAHA API key
WAHA_API_KEY=your-api-key-here

# Optional: Session name (default: "default")
WAHA_SESSION=default

# Optional: Minimum delay between outbound messages in ms (default: 1000)
WAHA_SEND_DELAY_MS=1000
