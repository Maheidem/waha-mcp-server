# Required: WAHA API base URL (no trailing slash)
WAHA_API_URL=http://localhost:3000/api

# Required: WAHA API key
WAHA_API_KEY=your-api-key-here

# Optional: Session name (default: "default")
WAHA_SESSION=default

# Optional: Minimum delay between outbound messages in ms (default: 1000)
WAHA_SEND_DELAY_MS=1000

# ── Transcription (optional) ──────────────────────────────────────
# Enables whatsapp_transcribe_audio tool. Activates if URL or API key is set.
# Defaults to self-hosted Speaches (Whisper) service. For OpenAI, set the API key
# and URL to https://api.openai.com/v1/audio/transcriptions.

# Transcription endpoint URL (default: self-hosted Speaches)
# WAHA_TRANSCRIPTION_URL=http://192.168.31.154:8100/v1/audio/transcriptions

# API key (default: "not-needed" for self-hosted; set to sk-... for OpenAI)
# WAHA_TRANSCRIPTION_API_KEY=not-needed

# Model name (default: "deepdml/faster-whisper-large-v3-turbo-ct2"; use "whisper-1" for OpenAI)
# WAHA_TRANSCRIPTION_MODEL=deepdml/faster-whisper-large-v3-turbo-ct2

# Language hint (default: "pt" for Portuguese; ISO 639-1 code)
# WAHA_TRANSCRIPTION_LANGUAGE=pt

# ── Message Store (optional) ─────────────────────────────────────
# Enables advanced features: full-text search, contact graph, chat summaries, stats.
# Requires a running Message Store API instance (see README).

# Base URL for the Message Store API (no trailing slash)
# WAHA_STORE_URL=http://localhost:8200/api

# API key for the Message Store (required if WAHA_STORE_URL is set)
# WAHA_STORE_API_KEY=your-store-api-key-here
